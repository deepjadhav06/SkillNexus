# Google Gemini API Key
# Get your free key from: https://aistudio.google.com/app/apikeys
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Backend Configuration
# LOCAL: DATABASE_URL=sqlite:///./skillnexus.db
# RAILWAY: Get DATABASE_URL from Railway PostgreSQL plugin (copy the full URL including postgresql://)
DATABASE_URL=postgresql://username:password@host:5432/dbname
SECRET_KEY=your_super_secret_key_change_this_in_production

# Frontend Configuration
# LOCAL: VITE_API_BASE=http://localhost:8000/api
# RAILWAY: VITE_API_BASE=https://your-railway-project.up.railway.app/api
VITE_API_BASE=http://localhost:8000/api
